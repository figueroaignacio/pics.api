# =============================================================================
# Application
# =============================================================================
APP_NAME="Pics API"
APP_ENV="development"       # development | staging | production
APP_VERSION="0.1.0"
DEBUG=true

# =============================================================================
# Database — PostgreSQL on Neon
# Accepted formats (the app auto-patches to postgresql+asyncpg://):
#   postgresql://user:password@host/dbname?sslmode=require
#   postgresql+asyncpg://user:password@host/dbname?ssl=require
# =============================================================================
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# Cloudflare R2 (S3-compatible object storage)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# =============================================================================
R2_ACCOUNT_ID="732f2edaedbfa52136de2c63032a702b"
R2_ACCESS_KEY_ID="64070d1478240f335725bc2a1d847f02"
R2_SECRET_ACCESS_KEY="fe0cc2e036f35f9e710a143c384a8ce754938a3cd12405df6640313744dc6382"
R2_BUCKET_NAME="pics"

# Public R2.dev subdomain — enable in: R2 → Bucket → Settings → Public Access
R2_PUBLIC_URL="https://732f2edaedbfa52136de2c63032a702b.r2.cloudflarestorage.com/pics"

# =============================================================================
# CORS  (comma-separated origins, or * for any)
# =============================================================================
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'
